    "score": null
  },
  {
    "id": "5cfdd3dc-09b4-4335-870f-0c0dbb2fb741",
    "text": "Q：API-KEY的上限个数是多少？",
    "media": null,
    "metadata": {
      "charset": "UTF-8",
      "chunk_index": 2,
      "article_type": "blog",
      "author": "wyy",
